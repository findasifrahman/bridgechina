{
  "name": "@bridgechina/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "postinstall": "prisma generate --schema=prisma/schema.ecommerce.prisma",
    "db:migrate": "prisma db push --schema=prisma/schema.ecommerce.prisma --force-reset",
    "db:migrate:dev": "prisma db push --schema=prisma/schema.ecommerce.prisma --force-reset",
    "db:deploy": "prisma migrate deploy --schema=prisma/schema.ecommerce.prisma",
    "db:patch:snapshots": "prisma db execute --schema=prisma/schema.ecommerce.prisma --file prisma/migrations/20260625121000_add_cart_order_item_snapshots/migration.sql",
    "db:patch:auth-email": "prisma db execute --schema=prisma/schema.ecommerce.prisma --file prisma/migrations/20260625123000_add_auth_email_otps/migration.sql",
    "db:patch:coupons": "prisma db execute --schema=prisma/schema.ecommerce.prisma --file prisma/migrations/20260626090000_add_coupons/migration.sql",
    "db:patch:tmapi": "prisma db execute --schema=prisma/schema.ecommerce.prisma --file prisma/migrations/20260626143000_add_tmapi_vendor_snapshots/migration.sql",
    "db:patch:prod": "pnpm db:patch:snapshots && pnpm db:patch:auth-email && pnpm db:patch:coupons && pnpm db:patch:tmapi",
    "db:push": "prisma db push --schema=prisma/schema.ecommerce.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:roles": "tsx scripts/seed-roles.ts",
    "sync:shopping-taxonomy": "tsx scripts/sync-shopping-taxonomy.ts",
    "verify:shopping-search": "tsx scripts/verify-shopping-search.ts",
    "db:studio": "prisma studio --schema=prisma/schema.ecommerce.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.ecommerce.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@bridgechina/shared": "workspace:*",
    "@fastify/cookie": "^9.2.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "fastify": "^4.25.2",
    "nodemailer": "^9.0.1",
    "openai": "^6.15.0",
    "sharp": "^0.33.2",
    "tsx": "^4.7.1",
    "twilio": "^5.3.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^5.9.1",
    "typescript": "^5.3.3"
  }
}
